# Supabase - required for storefront product reads and auth cookies.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase server-only key - required for orders, admin writes, inventory, and uploads.
# Never prefix this with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Admin - required for protected /admin access.
# Comma-separated Supabase Auth user emails that can access /admin.
ADMIN_EMAILS=

# Site URL / SEO - recommended for production canonical URLs, sitemap, robots, and email links.
# Example format: https://example.com
NEXT_PUBLIC_SITE_URL=

# Email notifications - optional and client-domain-dependent.
# Real delivery requires a verified sender domain in Resend.
RESEND_API_KEY=
EMAIL_FROM=
ADMIN_NOTIFICATION_EMAIL=
